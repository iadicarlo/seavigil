# Secrets - never commit API tokens
.env
*.env
!.env.example

# Python / uv
.venv/
__pycache__/
*.pyc
.ruff_cache/
.pytest_cache/
.ipynb_checkpoints/

# Data and model artifacts (regenerated)
data/raw/
data/processed/
models/
*.parquet
*.csv.gz

# Raw GFW API pulls (CC BY-NC; regenerate with a token, do not redistribute in bulk)
data/sar/gfw_*.geojson

# WDPA / WDOECM (UNEP-WCMC + IUCN; non-commercial, no downloadable redistribution)
*.gdb
data/mpa/wdpa_*.geojson

# Open AIS pulls (regenerate via scripts/fetch_open_ais.py)
data/positions/*_real.csv

# Keep placeholders
!**/.gitkeep

# OS / editor / tooling
.DS_Store
.idea/
.vscode/
node_modules/
.claude/

# NOAA Marine Cadastre raw AIS (large) + derived tracks
data/ais_raw/
data/positions/noaa_*.csv

# Marine Regions global EEZ/zone source (large; shipped as web/tiles/*.pmtiles)
data/eez/

# GFW AIS disabling events (CC BY-NC; derived dossiers shipped, not raw)
data/disabling/

# GFW transshipment events (CC BY-NC; derived dossiers shipped, not raw)
data/transshipment/

# Natural Earth basemap source (rebuilt by scripts/build_basemap.sh)
data/natural_earth/

# Transient live-monitor auth cache (re-queried each run)
data/authorizations_live.json

# Rolling AIS buffer for live spoofing (persisted via Actions cache, not committed)
data/positions/ais_buffer.csv
data/positions/ais_new.csv

# Live tracker SQLite (regenerated from the aisstream feed; never committed)
tracker/*.db
tracker/*.db-wal
tracker/*.db-shm

# Detection image chips (generated on the box from Copernicus scenes, served directly)
web/data/*/chips/

# The open Allen model repo, cloned + cached by the SAR engine workflow (never committed)
vendor/

# contact form submissions (VPS-local)
tracker/contact_inbox.jsonl
